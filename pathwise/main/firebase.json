{
  "hosting": [
    {
      "target": "pathskill",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "projects": {
    "default": "pathskill-app"
  }
}
